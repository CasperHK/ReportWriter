{
  "name": "report-writer",
  "version": "0.1.0",
  "description": "A desktop report writing application with smart citations and multi-format export.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron -c cyan,yellow \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "next dev src/renderer -p 3000",
    "dev:electron": "wait-on tcp:3000 && electron-vite dev",
    "build": "npm run build:renderer && electron-vite build",
    "build:renderer": "next build src/renderer",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p src/renderer/tsconfig.json"
  },
  "dependencies": {
    "docx": "^9.0.0",
    "katex": "^0.16.7"
  },
  "devDependencies": {
    "@types/katex": "^0.16.7",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "next": "^15.3.3",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3"
  }
}
